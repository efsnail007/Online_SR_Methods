APP_ENV=development

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
BACKEND_RELOAD=true
BACKEND_API_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

BACKEND_MODEL_NAME=RealESRGAN_x4plus
BACKEND_MODEL_WEIGHTS_PATH=src/backend/assets/weights/RealESRGAN_x4plus.pth
BACKEND_MODEL_DEVICE=auto
BACKEND_USE_HALF=true
BACKEND_USE_CHANNELS_LAST=true
BACKEND_DEFAULT_OUTSCALE=4.0

BACKEND_MAX_IMAGE_BYTES=5242880
BACKEND_OUTPUT_FORMAT=jpeg
BACKEND_JPEG_QUALITY=90
BACKEND_PNG_COMPRESSION=3

FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_CAMERA_WIDTH=640
VITE_CAMERA_HEIGHT=360
VITE_PROCESS_WIDTH=96
VITE_PROCESS_HEIGHT=54
VITE_CAPTURE_QUALITY=0.82
VITE_UPSCALE_OUTSCALE=4
VITE_OUTPUT_FORMAT=jpeg
